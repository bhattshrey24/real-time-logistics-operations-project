# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values before running any services.
# ─────────────────────────────────────────────────────────────────────────────

# ── MINIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
# Internal endpoint for Spark jobs running inside Docker (do not change for local dev)
MINIO_ENDPOINT=http://minio:9000
# Name of the MinIO bucket — must be created via http://localhost:9001 before running Spark jobs
MINIO_BUCKET=logistics

# ── KAFKA ─────────────────────────────────────────────────────────────────────
# Generate once with: docker run --rm confluentinc/cp-kafka:7.6.0 kafka-storage random-uuid
KAFKA_CLUSTER_ID=your_cluster_id
# Internal addresses used by Spark jobs running inside Docker (do not change for local dev)
KAFKA_BOOTSTRAP_SERVERS=kafka-1:29092,kafka-2:29092,kafka-3:29092

# ── POSTGRES ──────────────────────────────────────────────────────────────────
# Used by Airflow (metadata DB) and Script 4 (shipment_live RT table).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=airflow
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=airflow        # Airflow metadata — do not change
LOGISTICS_DB=logistics_rt  # Spark Script 4 writes shipment_live here

# ── SMTP (Script 4 alert emails) ──────────────────────────────────────────────
# Use an app password for Gmail (not your account password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=ops_team@yourcompany.com

# ── AIRFLOW ───────────────────────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your_airflow_password
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key
AIRFLOW_SECRET_KEY=your_secret_key
